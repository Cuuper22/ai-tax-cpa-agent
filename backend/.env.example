# ============================================================================
# AI API Keys
# ============================================================================

# REQUIRED for document analysis and audit defense features
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL - for future voice/TTS features (not currently used)
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite database path (file-based storage for conversation history)
DATABASE_URL=sqlite:///./tax_cpa.db

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, staging, production
APP_ENV=development

# Enable debug mode (set to false in production)
DEBUG=true

# Secret key for session management (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars

# API Server Port
PORT=8000

# ============================================================================
# CORS Settings
# ============================================================================

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Rate Limiting
# ============================================================================

# Maximum requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Voice/Avatar Features (OPTIONAL - not currently implemented)
# ============================================================================

# D-ID API for video avatars
DID_API_KEY=your_did_api_key_here

# HeyGen API for AI avatars
HEYGEN_API_KEY=your_heygen_api_key_here

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
#
# MINIMUM REQUIRED FOR BASIC TAX CALCULATIONS:
# - None! Tax calculations work without any API keys.
#
# REQUIRED FOR AI FEATURES (document/audit analysis):
# - ANTHROPIC_API_KEY
#
# VOICE FEATURES:
# - Not yet implemented. OPENAI_API_KEY and ELEVENLABS_API_KEY are placeholders.
#
# TO GET API KEYS:
# - Anthropic Claude: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/
# - ElevenLabs: https://elevenlabs.io/
#
# ============================================================================
